'resultado'
).innerHTML = '';

document.getElementById(
'pago'
).value='';

alert('🧹 Venta limpiada');

}

function limpiarHistorial(){

if(confirm('¿Eliminar historial?')){

historial = [];

guardar();

actualizarHistorial();

}

}

function reiniciarTodo(){

if(confirm('¿Reiniciar TODO el sistema?')){

inventario = [];
historial = [];
proveedores = [];
entradas = [];
cierres = [];

cajaDia = {
